# Runtime app connection. Use the scoped runtime role only.
DATABASE_URL="postgresql://entix_app_core_app:REPLACE_ME@en-os-data-db-postgres-main:5432/entix_app_core?schema=app"

# Migration-only connection. Use only in CI/admin migration jobs, never in browser code.
MIGRATION_DATABASE_URL="postgresql://entix_app_core_migrator:REPLACE_ME@en-os-data-db-postgres-main:5432/entix_app_core?schema=app"

# Better Auth server-side config.
BETTER_AUTH_URL="https://app.entix.app"
BETTER_AUTH_SECRET="replace-with-32-plus-random-chars"
GOOGLE_CLIENT_ID="replace-me.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="replace-me"

# Registration gate. Keep invite_only until CEO approves public signup.
ENTIX_AUTH_MODE="invite_only"
ENTIX_ADMIN_EMAILS=""

# Public app URL for client-side auth callbacks.
NEXT_PUBLIC_APP_URL="https://app.entix.app"

# Optional accounting bridge. Keep token server-side.
ENTIX_IO_API_URL="https://api.entix.io"
ENTIX_IO_API_TOKEN=""
ENTIX_IO_WEBHOOK_SECRET=""
