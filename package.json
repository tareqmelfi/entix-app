{
  "name": "entx-mang-entix-app",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\"",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "sh -c 'DATABASE_URL=${MIGRATION_DATABASE_URL:?MIGRATION_DATABASE_URL is required} prisma migrate deploy'",
    "prisma:migrate:dev": "sh -c 'DATABASE_URL=${MIGRATION_DATABASE_URL:?MIGRATION_DATABASE_URL is required} prisma migrate dev'",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "db:health": "tsx scripts/db-health.ts",
    "docker:build": "docker build -f docker/Dockerfile -t entix-app .",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@tanstack/react-query": "^5.62.0",
    "better-auth": "1.2.12",
    "clsx": "^2.1.1",
    "lucide-react": "0.468.0",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^2.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "22.10.2",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "8.4.49",
    "prettier": "3.4.2",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20 <26"
  },
  "packageManager": "pnpm@9.15.1"
}
